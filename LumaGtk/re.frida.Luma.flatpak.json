{
    "app-id": "re.frida.Luma",
    "runtime": "org.gnome.Platform",
    "runtime-version": "47",
    "sdk": "org.gnome.Sdk",
    "command": "luma",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=all",
        "--talk-name=org.freedesktop.Flatpak",
        "--system-talk-name=org.freedesktop.PolicyKit1",
        "--filesystem=home"
    ],
    "modules": [
        {
            "name": "swift",
            "buildsystem": "simple",
            "build-commands": [
                "tar xzf swift.tar.gz --strip-components=2 -C /app",
                "rm swift.tar.gz"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://download.swift.org/swift-6.1-release/ubuntu2404/swift-6.1-RELEASE/swift-6.1-RELEASE-ubuntu24.04.tar.gz",
                    "sha256": "57dbe6e85af6813b6013423d406e840bbb5ef14d7ef29eac1bfdb83d33e32c59",
                    "dest-filename": "swift.tar.gz"
                }
            ]
        },
        {
            "name": "libgee",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/libgee/0.20/libgee-0.20.6.tar.xz",
                    "sha256": "1bf834f5e10d60cc6124d74ed3c1dd38da646787fbf7872220b8b4068e476d4d"
                }
            ]
        },
        {
            "name": "frida-core",
            "buildsystem": "simple",
            "build-commands": [
                "./configure --enable-shared --without-prebuilds=sdk --prefix=/app -- --force-fallback-for=openssl",
                "make -j$(nproc)",
                "make install"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/frida/frida-core.git",
                    "branch": "main"
                }
            ]
        },
        {
            "name": "radare2",
            "buildsystem": "meson",
            "config-opts": ["-Ddefault_library=static", "-Dstatic_runtime=true"],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/radareorg/radare2/archive/65ee12a4f0d67f24a1b968111c536de3bb5bb4e3.tar.gz",
                    "sha256": "d00a38d6219350d1da5ba2b454f4a46e06daa66c509b5b6a2a9d6bcaaef3b1a6",
                    "strip-components": 1
                }
            ]
        },
        {
            "name": "nodejs",
            "buildsystem": "simple",
            "build-commands": [
                "tar xJf node.tar.xz --strip-components=1 -C /app",
                "rm node.tar.xz"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://nodejs.org/dist/v20.18.0/node-v20.18.0-linux-x64.tar.xz",
                    "sha256": "4543670b589593f8fa5f106111fd5139081da42bb165a9239f05195e405f240a",
                    "dest-filename": "node.tar.xz"
                }
            ]
        },
        {
            "name": "luma",
            "buildsystem": "simple",
            "build-commands": [
                "cd LumaGtk && make build SWIFT_BUILD_FLAGS='-c release'",
                "install -Dm755 LumaGtk/.build/release/LumaGtk /app/bin/luma",
                "install -Dm644 LumaGtk/data/re.frida.Luma.desktop /app/share/applications/re.frida.Luma.desktop",
                "install -Dm644 LumaGtk/data/re.frida.Luma.xml /app/share/mime/packages/re.frida.Luma.xml"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/frida/luma.git",
                    "branch": "cross-platform"
                }
            ]
        }
    ]
}
