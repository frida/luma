{
    "app-id": "re.frida.Luma",
    "runtime": "org.gnome.Platform",
    "runtime-version": "47",
    "sdk": "org.gnome.Sdk",
    "command": "luma",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=all",
        "--talk-name=org.freedesktop.Flatpak",
        "--system-talk-name=org.freedesktop.PolicyKit1",
        "--filesystem=home"
    ],
    "modules": [
        {
            "name": "swift",
            "buildsystem": "simple",
            "build-commands": [
                "tar xzf swift.tar.gz --strip-components=2 -C /app",
                "rm swift.tar.gz"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://download.swift.org/swift-6.0.3-release/ubuntu2404/swift-6.0.3-RELEASE/swift-6.0.3-RELEASE-ubuntu24.04.tar.gz",
                    "sha256": "",
                    "dest-filename": "swift.tar.gz",
                    "x-checker-data": {
                        "type": "html",
                        "comment": "Update SHA256 after downloading"
                    }
                }
            ]
        },
        {
            "name": "radare2",
            "buildsystem": "meson",
            "config-opts": [
                "-Dprefix=/app"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/radareorg/radare2/releases/download/5.9.8/radare2-5.9.8.tar.xz",
                    "sha256": ""
                }
            ]
        },
        {
            "name": "frida-core",
            "buildsystem": "simple",
            "build-commands": [
                "tar xJf frida-core-devkit.tar.xz",
                "install -Dm644 libfrida-core.a /app/lib/libfrida-core.a",
                "install -Dm644 frida-core.h /app/include/frida/frida-core.h",
                "mkdir -p /app/lib/pkgconfig",
                "cat > /app/lib/pkgconfig/frida-core-1.0.pc <<EOF\nprefix=/app\nlibdir=${prefix}/lib\nincludedir=${prefix}/include/frida\n\nName: frida-core\nDescription: Frida core library\nVersion: 17.9.1\nLibs: -L${libdir} -lfrida-core -lresolv -ldl -lrt -lm -lpthread\nCflags: -I${includedir}\nEOF"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://github.com/frida/frida/releases/download/17.9.1/frida-core-devkit-17.9.1-linux-x86_64.tar.xz",
                    "sha256": "",
                    "dest-filename": "frida-core-devkit.tar.xz"
                }
            ]
        },
        {
            "name": "nodejs",
            "buildsystem": "simple",
            "build-commands": [
                "tar xJf node.tar.xz --strip-components=1 -C /app",
                "rm node.tar.xz"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://nodejs.org/dist/v20.18.0/node-v20.18.0-linux-x64.tar.xz",
                    "sha256": "",
                    "dest-filename": "node.tar.xz"
                }
            ]
        },
        {
            "name": "luma",
            "buildsystem": "simple",
            "build-commands": [
                "cd LumaGtk && make build SWIFT_BUILD_FLAGS='-c release'",
                "install -Dm755 LumaGtk/.build/release/LumaGtk /app/bin/luma",
                "install -Dm644 LumaGtk/data/re.frida.Luma.desktop /app/share/applications/re.frida.Luma.desktop",
                "install -Dm644 LumaGtk/data/re.frida.Luma.xml /app/share/mime/packages/re.frida.Luma.xml"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/frida/luma.git",
                    "branch": "cross-platform"
                }
            ]
        }
    ]
}
