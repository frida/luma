{
    "app-id": "re.frida.Luma",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "luma",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=all",
        "--talk-name=org.freedesktop.Flatpak",
        "--system-talk-name=org.freedesktop.PolicyKit1",
        "--filesystem=home"
    ],
    "build-options": {
        "build-args": ["--share=network"],
        "append-path": "/app/lib/sdk-go/bin",
        "env": {
            "PKG_CONFIG_PATH": "/app/lib64/pkgconfig"
        }
    },
    "cleanup": [
        "/bin/clang*",
        "/bin/lld*",
        "/bin/lldb*",
        "/bin/llvm-*",
        "/bin/swift*",
        "/bin/swiftc*",
        "/bin/sourcekit-lsp",
        "/bin/docc",
        "/bin/wasmkit*",
        "/bin/plutil",
        "/bin/repl_swift",
        "/bin/sdk-module-lists",
        "/bin/node",
        "/bin/npm",
        "/bin/npx",
        "/bin/corepack",
        "/bin/frida-server",
        "/bin/frida-portal",
        "/bin/frida-inject",
        "/lib64/frida-1.0/*/frida-gadget*",
        "/include",
        "/lib/liblldb*",
        "/lib/libsourcekitdInProc*",
        "/lib/libclang*",
        "/lib/libLTO*",
        "/lib/libIndexStore*",
        "/lib/libSwiftSourceKit*",
        "/lib/libswiftDemangle*",
        "/lib/swift/embedded",
        "/lib/swift/host",
        "/lib/swift_static",
        "/lib/swift/musl",
        "/lib/sdk-go",
        "/lib/clang",
        "/lib/node_modules",
        "/lib64/pkgconfig",
        "/share/vala",
        "/share/docc",
        "/share/man",
        "/share/gir-1.0",
        "/share/radare2/*/scripts",
        "/share/radare2/*/www",
        "/lib64/girepository-1.0",
        "*.a",
        "*.la",
        "*.pc"
    ],
    "modules": [
        {
            "name": "nodejs",
            "buildsystem": "simple",
            "build-commands": [
                "tar xJf node.tar.xz --strip-components=1 -C /app",
                "rm node.tar.xz"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://nodejs.org/dist/v20.18.0/node-v20.18.0-linux-x64.tar.xz",
                    "sha256": "4543670b589593f8fa5f106111fd5139081da42bb165a9239f05195e405f240a",
                    "dest-filename": "node.tar.xz"
                }
            ]
        },
        {
            "name": "swift",
            "buildsystem": "simple",
            "build-commands": [
                "tar xzf swift.tar.gz --strip-components=2 -C /app",
                "rm swift.tar.gz",
                "ln -sf /usr/lib/x86_64-linux-gnu/libxml2.so.16 /app/lib/swift/linux/libxml2.so.2"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://download.swift.org/swift-6.2-release/ubuntu2404/swift-6.2-RELEASE/swift-6.2-RELEASE-ubuntu24.04.tar.gz",
                    "sha256": "8e3d63a3371caad495e694414b9b9a22c5f68c6473077406c7296472a41bc077",
                    "dest-filename": "swift.tar.gz"
                }
            ]
        },
        {
            "name": "go",
            "buildsystem": "simple",
            "build-commands": [
                "install -d /app/lib/sdk-go",
                "tar xzf go.tar.gz -C /app/lib/sdk-go --strip-components=1",
                "rm go.tar.gz"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://go.dev/dl/go1.26.2.linux-amd64.tar.gz",
                    "sha256": "990e6b4bbba816dc3ee129eaeaf4b42f17c2800b88a2166c265ac1a200262282",
                    "dest-filename": "go.tar.gz"
                }
            ]
        },
        {
            "name": "frida-core",
            "buildsystem": "simple",
            "build-commands": [
                "./configure --enable-shared --enable-compiler-backend --without-prebuilds=sdk --prefix=/app -- --force-fallback-for=openssl,libbpf",
                "make -j$(nproc)",
                "DESTDIR=$PWD/_destdir python3 releng/meson/meson.py install -C build --skip-subprojects --no-rebuild",
                "cp -a _destdir/app/. /app/"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/frida/frida-core.git",
                    "branch": "main"
                }
            ]
        },
        {
            "name": "libzip",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DBUILD_SHARED_LIBS=OFF",
                "-DBUILD_TOOLS=OFF",
                "-DBUILD_REGRESS=OFF",
                "-DBUILD_EXAMPLES=OFF",
                "-DBUILD_DOC=OFF",
                "-DENABLE_BZIP2=OFF",
                "-DENABLE_LZMA=OFF",
                "-DENABLE_ZSTD=OFF",
                "-DENABLE_GNUTLS=OFF",
                "-DENABLE_MBEDTLS=OFF",
                "-DENABLE_OPENSSL=OFF"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://libzip.org/download/libzip-1.11.4.tar.gz",
                    "sha256": "82e9f2f2421f9d7c2466bbc3173cd09595a88ea37db0d559a9d0a2dc60dc722e"
                }
            ]
        },
        {
            "name": "radare2",
            "buildsystem": "meson",
            "config-opts": [
                "--default-library=static",
                "-Dstatic_runtime=true",
                "-Dcli=disabled",
                "-Duse_sys_zip=true"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/radareorg/radare2/archive/7ed1e8c6fd000b99c8aa6835e12bef1657d92746.tar.gz",
                    "sha256": "1b7605917611a08124799cf70eedf96b0f9d8f3a1474782c6b6b4eeea00ebe40",
                    "strip-components": 1
                }
            ]
        },
        {
            "name": "luma",
            "buildsystem": "simple",
            "build-commands": [
                "cd LumaGtk && make build SWIFT_BUILD_FLAGS='-c release'",
                "install -Dm755 LumaGtk/.build/x86_64-unknown-linux-gnu/release/LumaGtk /app/bin/luma",
                "strip --strip-unneeded /app/bin/luma",
                "for bundle in LumaGtk/.build/x86_64-unknown-linux-gnu/release/*.resources; do [ -d \"$bundle\" ] && cp -a \"$bundle\" /app/bin/; done",
                "install -Dm644 LumaGtk/data/re.frida.Luma.desktop /app/share/applications/re.frida.Luma.desktop",
                "install -Dm644 LumaGtk/data/re.frida.Luma.xml /app/share/mime/packages/re.frida.Luma.xml",
                "for size in 32 48 64 128 256 512; do install -Dm644 LumaGtk/data/icons/hicolor/${size}x${size}/apps/re.frida.Luma.png /app/share/icons/hicolor/${size}x${size}/apps/re.frida.Luma.png; done"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/frida/luma.git",
                    "branch": "main"
                }
            ]
        }
    ]
}
